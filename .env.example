# Copy to `.env` (git-ignored). All values optional — the pipeline runs without them.

# Enable LLM re-scoring of the shortlist (optional — heuristic scoring works without it)
# ANTHROPIC_API_KEY=sk-ant-...
# JOBSCREENER_MODEL=claude-sonnet-5

# Live LinkedIn source via Apify (run: jobscreener run --source apify --apify-input apify_input.json)
# APIFY_TOKEN=apify_api_...
# JOBSCREENER_APIFY_ACTOR=cheap_scraper~linkedin-job-scraper
# JOBSCREENER_APIFY_INPUT=apify_input.json   # the actor input copied from Apify's JSON tab

# Proxies for the JobSpy source (only needed if LinkedIn rate-limits you).
# Comma-separated: host:port  or  user:pass@host:port
# JOBSCREENER_PROXIES=user:pass@1.2.3.4:8000,user:pass@5.6.7.8:8000

# Override inputs/outputs
# JOBSCREENER_CV=../career/PROFILE.md
# JOBSCREENER_JOBS=data/sample_jobs.json
# JOBSCREENER_OUTPUT=output

# Push the daily shortlist to a Notion database (auto when both are set)
# Create an integration at https://www.notion.so/my-integrations, share your DB with it.
# NOTION_TOKEN=ntn_...
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email delivery (Gmail needs an App Password)
# JOBSCREENER_SMTP_HOST=smtp.gmail.com
# JOBSCREENER_SMTP_PORT=465
# JOBSCREENER_SMTP_USER=you@gmail.com
# JOBSCREENER_SMTP_PASS=your_app_password
# JOBSCREENER_EMAIL_TO=you@gmail.com
